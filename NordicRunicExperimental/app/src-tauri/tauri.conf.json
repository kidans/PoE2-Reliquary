{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reliquary Runic Experiment",
  "version": "0.0.1",
  "identifier": "com.reliquary.runic-experiment",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5177",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Reliquary Runic Experiment",
        "width": 1210,
        "height": 910,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": false
  }
}
